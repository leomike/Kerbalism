<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>3.40.0</Version>
    <FileVersion>$(Version)</FileVersion>
    <AssemblyName>Kerbalism</AssemblyName>
    <RootNamespace>KERBALISM</RootNamespace>
    <TargetFramework>net481</TargetFramework>

    <Description>Hundreds of Kerbals were killed in the making of this mod.</Description>
    <Product>Kerbalism</Product>
    <ComVisible>false</ComVisible>

    <KSPBT_ModRoot>$(ProjectRootDir)GameData\Kerbalism</KSPBT_ModRoot>
    <KSPBT_ModPluginFolder>.</KSPBT_ModPluginFolder>
    <!-- Opt-in: copy GameData to the live KSP install. Set in Kerbalism.props.user. -->
    <Kerbalism_DeployToKsp Condition=" '$(Kerbalism_DeployToKsp)' == '' ">false</Kerbalism_DeployToKsp>

    <LangVersion>latest</LangVersion>
    <DebugType>portable</DebugType>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(KSPBT_ModVersion)' != '' ">
    <Version>$(KSPBT_ModVersion)</Version>
    <FileVersion>$(Version)</FileVersion>
  </PropertyGroup>

  <ItemGroup>
    <!-- System Dlls -->
    <Reference Include="System">
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Core">
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Xml">
      <Private>False</Private>
    </Reference>
    <Reference Include="System.Xml.Linq">
      <Private>False</Private>
    </Reference>
    <!-- Harmony reference, get it from the gamedata folder -->
    <Reference Include="0Harmony, Version=2.2.1.0, Culture=neutral, processorArchitecture=MSIL">
      <HintPath>$(KSPDevPath)\GameData\000_Harmony\0Harmony.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <!-- KSP Dlls -->
    <Reference Include="$(EffectiveKSPDllPath)\Assembly-CSharp.dll">
      <Private>False</Private>
    </Reference>
    <Reference Include="$(EffectiveKSPDllPath)\Assembly-CSharp-firstpass.dll">
      <Private>False</Private>
    </Reference>
    <!-- load all UnityEngine Dlls (since 1.8 we only need those) -->
    <Reference Include="$(EffectiveKSPDllPath)\UnityEngine*.dll">
      <Private>False</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Output/**" />
    <Compile Remove="Modules/KerbalismProcess.cs" />
    <Compile Remove="Comms/Communications.cs" />
    <Compile Remove="Science/ScienceRestriction.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="KSPBuildTools" Version="1.1.1" />
  </ItemGroup>

  <ItemGroup>
    <ModReference Include="0Harmony">
      <DLLPath>GameData/000_Harmony/0Harmony.dll</DLLPath>
      <CKANIdentifier>Harmony2</CKANIdentifier>
      <KSPAssemblyVersion>0.0</KSPAssemblyVersion>
    </ModReference>
  </ItemGroup>

  <ItemGroup>
    <KSPVersionFile Include=".">
      <Destination>$(KSPBT_ModRoot)/Kerbalism.version</Destination>
      <URL>https://raw.githubusercontent.com/Kerbalism/Kerbalism/master/GameData/Kerbalism/Kerbalism.version</URL>
      <Download>https://github.com/Kerbalism/Kerbalism/releases</Download>
      <KSP_Version>1.12.5</KSP_Version>
      <KSP_Version_Min>1.12.0</KSP_Version_Min>
      <KSP_Version_Max>1.12.99</KSP_Version_Max>
    </KSPVersionFile>
  </ItemGroup>

  <ItemGroup>
    <None Update=".ksplocalizer.settings">
      <Generator>SettingsSingleFileGenerator</Generator>
    </None>
  </ItemGroup>

  <Target Name="DeployGameDataToKsp" AfterTargets="KSPBT_CopyDLLsToPluginFolder"
          Condition=" '$(Kerbalism_DeployToKsp)' == 'true' And '$(KSPBT_GameRoot)' != '' ">
    <PropertyGroup>
      <_KspKerbalismDeployDir>$(KSPBT_GameRoot)/GameData/Kerbalism</_KspKerbalismDeployDir>
      <_KspKerbalismConfigDeployDir>$(KSPBT_GameRoot)/GameData/KerbalismConfig</_KspKerbalismConfigDeployDir>
    </PropertyGroup>
    <ItemGroup>
      <_KerbalismDeployFiles Include="$(KSPBT_ModRoot)/**/*" />
      <_KerbalismConfigDeployFiles Include="$(ProjectRootDir)GameData/KerbalismConfig/**/*" />
    </ItemGroup>
    <Copy SourceFiles="@(_KerbalismDeployFiles)" DestinationFolder="$(_KspKerbalismDeployDir)/%(RecursiveDir)" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(_KerbalismConfigDeployFiles)" DestinationFolder="$(_KspKerbalismConfigDeployDir)/%(RecursiveDir)" SkipUnchangedFiles="true" />
    <Message Text="Deployed GameData/Kerbalism and GameData/KerbalismConfig to $(KSPBT_GameRoot)" Importance="high" />
  </Target>
</Project>
